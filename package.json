{
  "name": "dependabit",
  "version": "0.1.16",
  "private": true,
  "description": "dependabot for resources, related projects, and knowledge",
  "keywords": [
    "dependency",
    "monitoring",
    "security",
    "vulnerability",
    "changelog",
    "version-tracking",
    "github",
    "automation",
    "ai"
  ],
  "type": "module",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/dependabit.git"
  },
  "homepage": "https://pradeepmouli.github.io/dependabit/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/dependabit/issues"
  },
  "workspaces": [
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean && find packages -name 'tsconfig.tsbuildinfo' -delete && rm -rf node_modules/.cache",
    "clean:all": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version && node scripts/sync-root-version.mjs",
    "dev": "pnpm -r --parallel run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fresh": "pnpm clean:all && pnpm install",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "pnpm -r run type-check",
    "prepare": "simple-git-hooks",
    "docs:dev": "pnpm --filter @dependabit/docs dev",
    "docs:build": "pnpm --filter @dependabit/docs build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@to-skills/vitepress": "^0.2.18",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "simple-git-hooks": "^2.13.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-to-skills": "^1.0.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.32.0"
  },
  "packageManager": "pnpm@10.32.0",
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm run type-check"
  },
  "pnpm": {
    "overrides": {
      "@typescript/native-preview": "7.0.0-dev.20260219.1"
    }
  }
}

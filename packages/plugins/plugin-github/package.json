{
  "name": "@dependabit/plugin-github",
  "version": "0.1.14",
  "description": "GitHub releases, tags, and raw file checker plugin for dependabit — monitors repository-hosted dependency sources.",
  "homepage": "https://pradeepmouli.github.io/dependabit/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/dependabit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pradeepmouli/dependabit.git",
    "directory": "packages/plugins/plugin-github"
  },
  "license": "MIT",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dependabit/github-client": "workspace:*",
    "@dependabit/manifest": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "github",
    "plugin",
    "dependabit",
    "releases",
    "tags",
    "commits"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}

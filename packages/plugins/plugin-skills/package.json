{
  "name": "@dependabit/plugin-skills",
  "version": "0.1.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/dependabit",
    "directory": "packages/plugins/plugin-skills"
  },
  "description": "Skills.sh plugin for tracking AI agent skill versions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dependabit/manifest": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "plugin",
    "skills",
    "skills.sh",
    "agent-skills"
  ],
  "license": "MIT"
}

{
  "name": "@dependabit/detector",
  "version": "0.1.16",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/dependabit.git",
    "directory": "packages/detector"
  },
  "homepage": "https://pradeepmouli.github.io/dependabit/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/dependabit/issues"
  },
  "description": "Detect external dependencies from READMEs, code comments, diffs, and package files using LLM-assisted parsing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@dependabit/github-client": "workspace:*",
    "@dependabit/manifest": "workspace:*",
    "ignore": "^7.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "dependabit",
    "dependency",
    "detection",
    "llm",
    "ai",
    "copilot",
    "parser"
  ],
  "license": "MIT",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}

{
  "name": "@dependabit/github-client",
  "version": "0.1.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/dependabit.git",
    "directory": "packages/github-client"
  },
  "homepage": "https://pradeepmouli.github.io/dependabit/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/dependabit/issues"
  },
  "description": "Octokit-based GitHub client for dependabit with auth, rate-limit budgeting, issue, release, and feedback helpers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/github": "^9.1.0",
    "octokit": "^5.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "dependabit",
    "github",
    "octokit",
    "api",
    "rate-limit",
    "automation"
  ],
  "license": "MIT",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}

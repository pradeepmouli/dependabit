{
  "name": "@dependabit/utils",
  "version": "0.1.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/dependabit.git",
    "directory": "packages/utils"
  },
  "homepage": "https://pradeepmouli.github.io/dependabit/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/dependabit/issues"
  },
  "description": "String and array helpers used across dependabit, with tree-shakeable /string and /array subpath exports.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./string": {
      "types": "./dist/string.d.ts",
      "default": "./dist/string.js"
    },
    "./array": {
      "types": "./dist/array.d.ts",
      "default": "./dist/array.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "dependabit",
    "utils",
    "helpers",
    "string",
    "array",
    "typescript"
  ],
  "license": "MIT",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}

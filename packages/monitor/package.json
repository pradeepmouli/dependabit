{
  "name": "@dependabit/monitor",
  "version": "0.1.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/dependabit.git",
    "directory": "packages/monitor"
  },
  "homepage": "https://pradeepmouli.github.io/dependabit/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/dependabit/issues"
  },
  "description": "Poll GitHub repos, URLs, and OpenAPI specs for changes with snapshot diffing and severity classification.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dependabit/manifest": "workspace:*",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "dependabit",
    "monitor",
    "change-detection",
    "dependency",
    "openapi",
    "diff"
  ],
  "license": "MIT",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
